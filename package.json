{
  "name": "menumaster",
  "version": "1.0.0",
  "description": "Full-stack recipe catering calculator",
  "scripts": {
    "start": "npm run dev",
    "kill-ports": "npx kill-port 3000 3001 || exit 0",
    "backend": "cd server && npm run dev",
    "frontend": "cd client && npm run dev",
    "dev": "npm run kill-ports && npx concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm install --prefix client && npm run build --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "concurrently": "^8.2.2"
  }
}
