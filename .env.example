# Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=3000

# Local development MongoDB (using 127.0.0.1 for better Windows compatibility)
MONGO_URI=mongodb://127.0.0.1:27017/menumaster

# Production: MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/menumaster?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
